# Langfuse self-hosted stack — env template.
# Copy to ./.env in this directory and fill in secrets before `docker compose up`.

# ── Public URL of the Langfuse web UI (used for NextAuth callbacks). ──────────
# For local dev this is typically fine as-is. Change to your public hostname if
# you run Langfuse on a shared host.
NEXTAUTH_URL=http://localhost:3100

# ── Host port bindings (change if you have conflicts). ────────────────────────
# Default web port is 3100 (not 3000) to avoid colliding with the demo frontend.
LANGFUSE_WEB_PORT=3100
# MinIO API (S3-compatible) — served to the browser for signed media URLs.
MINIO_API_PORT=9190
# MinIO console (not strictly needed) — localhost-only.
MINIO_CONSOLE_PORT=9191

# ── Secrets (all required — generate before bringing the stack up). ───────────
# openssl rand -hex 32
NEXTAUTH_SECRET=REPLACE_ME_nextauth_secret
# openssl rand -hex 32
SALT=REPLACE_ME_salt
# openssl rand -hex 32  (exactly 64 hex chars)
ENCRYPTION_KEY=REPLACE_ME_encryption_key_64_hex

# Postgres.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=REPLACE_ME_postgres_password
POSTGRES_DB=postgres

# ClickHouse.
CLICKHOUSE_USER=clickhouse
CLICKHOUSE_PASSWORD=REPLACE_ME_clickhouse_password

# MinIO.
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=REPLACE_ME_minio_secret

# Redis.
REDIS_AUTH=REPLACE_ME_redis_secret

# Anonymized usage telemetry to Langfuse Cloud (set false to disable).
TELEMETRY_ENABLED=true

# ── Optional: auto-bootstrap an org / project / user on first boot. ───────────
# If all INIT_* values are set, Langfuse creates them automatically and you can
# log in immediately. Leave blank to go through the UI signup flow manually.
LANGFUSE_INIT_ORG_ID=
LANGFUSE_INIT_ORG_NAME=
LANGFUSE_INIT_PROJECT_ID=
LANGFUSE_INIT_PROJECT_NAME=
LANGFUSE_INIT_PROJECT_PUBLIC_KEY=
LANGFUSE_INIT_PROJECT_SECRET_KEY=
LANGFUSE_INIT_USER_EMAIL=
LANGFUSE_INIT_USER_NAME=
LANGFUSE_INIT_USER_PASSWORD=
