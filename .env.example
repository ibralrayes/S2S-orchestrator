# Internal LiveKit websocket URL used by containers and the agent worker.
LIVEKIT_URL=ws://livekit-server:7880
# Public LiveKit URL returned to frontend clients by the token server.
LIVEKIT_PUBLIC_URL=ws://localhost:7880
# LiveKit API key used to sign and validate access tokens.
LIVEKIT_API_KEY=devkey
# LiveKit API secret paired with the API key above.
LIVEKIT_API_SECRET=secret

# Port exposed by the token server.
TOKEN_SERVER_PORT=8080
# Lifetime of generated client tokens in minutes.
TOKEN_TTL_MINUTES=60
# Comma-separated frontend origins allowed to call the token server.
TOKEN_CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Registered LiveKit agent name for dispatch.
AGENT_NAME=nusuk-agent
# System prompt sent to the LLM for every session.
AGENT_SYSTEM_PROMPT=You are a concise, helpful Arabic-first voice assistant.
# Spoken greeting the agent says after joining the room.
AGENT_GREETING=مرحبا، أنا مساعدك الصوتي. كيف أقدر أساعدك؟
# Enable LiveKit turn detector model in addition to VAD.
AGENT_USE_TURN_DETECTOR=false
# Silero VAD activation threshold.
AGENT_VAD_ACTIVATION_THRESHOLD=0.5
# Allow the user to interrupt the assistant while it is speaking.
AGENT_ALLOW_INTERRUPTIONS=true
# Drop buffered input audio when interruptions are disabled.
AGENT_DISCARD_AUDIO_IF_UNINTERRUPTIBLE=true
# Minimum speech duration in seconds to count as an interruption.
AGENT_MIN_INTERRUPTION_DURATION=0.5
# Minimum words needed before STT-based interruption is accepted.
AGENT_MIN_INTERRUPTION_WORDS=0
# Minimum silence delay before ending the user's turn.
AGENT_MIN_ENDPOINTING_DELAY=0.5
# Maximum wait before LiveKit forces turn completion.
AGENT_MAX_ENDPOINTING_DELAY=5.0
# How long to wait before treating an interruption as false.
AGENT_FALSE_INTERRUPTION_TIMEOUT=2.0
# Resume assistant speech automatically after a false interruption.
AGENT_RESUME_FALSE_INTERRUPTION=true
# Extra speech delay guard before interruption logic triggers.
AGENT_MIN_CONSECUTIVE_SPEECH_DELAY=0.0
# Align emitted assistant transcripts to the timing of TTS audio.
AGENT_USE_TTS_ALIGNED_TRANSCRIPT=false
# Link the agent to a specific participant identity instead of the first participant.
AGENT_PARTICIPANT_IDENTITY=
# Close the session when the linked participant disconnects.
AGENT_CLOSE_ON_DISCONNECT=true
# Delete the room when the session closes.
AGENT_DELETE_ROOM_ON_CLOSE=false

# ASR transcription endpoint.
CUSTOM_STT_URL=http://replace-me/v1/audio/transcriptions
# ASR model name passed to the endpoint.
CUSTOM_STT_MODEL=whisper-large-v3
# Language hint sent to ASR.
CUSTOM_STT_LANGUAGE=ar
# ASR request timeout in seconds.
CUSTOM_STT_TIMEOUT_SECONDS=30
# Target sample rate used when resampling audio before ASR.
CUSTOM_STT_TARGET_SAMPLE_RATE=16000

# Base URL for the LLM API.
CUSTOM_LLM_URL=http://replace-me/v1
# LLM model name used for chat completions.
CUSTOM_LLM_MODEL=placeholder
# Sampling temperature for the LLM.
CUSTOM_LLM_TEMPERATURE=0.2
# Maximum generated tokens per response.
CUSTOM_LLM_MAX_TOKENS=256
# LLM request timeout in seconds.
CUSTOM_LLM_TIMEOUT_SECONDS=60

# TTS synthesis endpoint.
CUSTOM_TTS_URL=http://replace-me/v1/audio/speech
# TTS model name passed to the endpoint.
CUSTOM_TTS_MODEL=placeholder
# Voice name requested from the TTS service.
CUSTOM_TTS_VOICE=default
# Sample rate expected from the TTS output stream.
CUSTOM_TTS_SAMPLE_RATE=24000
# Number of audio channels expected from TTS output.
CUSTOM_TTS_NUM_CHANNELS=1
# Response format requested from TTS, usually wav or pcm.
CUSTOM_TTS_AUDIO_FORMAT=wav
# TTS request timeout in seconds.
CUSTOM_TTS_TIMEOUT_SECONDS=60
